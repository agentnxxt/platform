# ══════════════════════════════════════════════════════════════════════════
# AgentNext Platform — Environment Variables
# Copy to .env and fill in required values
# ══════════════════════════════════════════════════════════════════════════

# ── Database ─────────────────────────────────────────────────────────────
POSTGRES_USER=platform
POSTGRES_PASSWORD=CHANGE_ME

# ── LLM Gateway ──────────────────────────────────────────────────────────
LITELLM_MASTER_KEY=sk-CHANGE_ME
LITELLM_UI_USERNAME=admin
LITELLM_UI_PASSWORD=CHANGE_ME

# LLM Provider Keys (add the ones you use)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# ── ObserveLLM ───────────────────────────────────────────────────────────
# Set these after first login to ObserveLLM UI
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_NEXT_AUTH_SECRET=CHANGE_ME
LANGFUSE_SALT=CHANGE_ME

# ── Billing ──────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 64
LAGO_SECRET_KEY_BASE=CHANGE_ME
# Generate: openssl genrsa 2048 | base64
LAGO_RSA_PRIVATE_KEY=CHANGE_ME
# Generate: openssl rand -hex 16 (run 3 times)
LAGO_ENCRYPTION_PRIMARY_KEY=CHANGE_ME
LAGO_ENCRYPTION_DETERMINISTIC_KEY=CHANGE_ME
LAGO_ENCRYPTION_KEY_DERIVATION_SALT=CHANGE_ME
# Set after creating Billing org
LAGO_API_KEY=

# ── Auth Server (Logto) ──────────────────────────────────────────────────
# AUTH_PORT=3301
# AUTH_ADMIN_PORT=3302
# LOGTO_ENDPOINT=http://localhost:3301
# LOGTO_ADMIN_ENDPOINT=http://localhost:3302

# ── Mail Server ──────────────────────────────────────────────────────────
STALWART_HOSTNAME=mail.example.com
ADMIN_SECRET=CHANGE_ME

# ── Ports (change if defaults conflict) ──────────────────────────────────
# AGENTFLOW_PORT=7860
# GATEWAY_PORT=4000
# OBSERVELLM_PORT=3150
# LOCALLLM_PORT=11434
# BILLING_API_PORT=3200
# BILLING_FRONT_PORT=3201
# BRIDGE_PORT=8090
# MAIL_PORT=4500
